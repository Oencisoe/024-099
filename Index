<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Independent Facilitation Services Agreement – EF-IF</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: Arial, sans-serif; font-size: 9pt; color: #111; background: #ddd; line-height: 1.35; }

  .page {
    background: #fff;
    width: 8.5in;
    min-height: 11in;
    margin: 0.15in auto;
    padding: 0.28in 0.48in 0.2in;
    box-shadow: 0 2px 12px rgba(0,0,0,0.18);
    display: flex;
    flex-direction: column;
  }

  @media print {
    html, body { background: #fff; margin: 0; padding: 0; }
    .page { box-shadow: none; margin: 0; padding: 0.28in 0.48in 0.2in; width: 8.5in; height: 11in; overflow: hidden; }
    .print-btn { display: none !important; }
    select { -webkit-appearance: none; appearance: none; border: none !important; background: transparent !important; font-weight: bold; color: #000; font-family: Arial, sans-serif; }
    @page { size: letter; margin: 0; }
  }

  .hdr { display: flex; align-items: center; gap: 10px; margin-bottom: 4px; border-bottom: 1.5px solid #000; padding-bottom: 4px; }
  .hdr img { height: 42px; width: auto; }
  .hdr-txt { font-size: 8pt; line-height: 1.3; }
  .hdr-txt strong { font-size: 9.5pt; }

  .doc-title { text-align: center; font-size: 11pt; font-weight: bold; letter-spacing: 0.4px; text-transform: uppercase; margin: 4px 0 1px; }
  .doc-sub   { text-align: center; font-size: 9pt; font-weight: bold; margin-bottom: 3px; }
  .intro { font-size: 8.5pt; margin-bottom: 4px; line-height: 1.35; }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 0 18px; flex: 1; }

  .sh { font-weight: bold; font-size: 8.5pt; text-transform: uppercase; margin: 5px 0 1px; border-bottom: 1px solid #bbb; padding-bottom: 1px; }
  p { margin-bottom: 3px; font-size: 8.5pt; line-height: 1.35; }

  ul.tl { margin: 1px 0 3px 13px; }
  ul.tl > li { font-size: 8.5pt; margin-bottom: 1px; list-style: disc; }
  ul.sub { margin: 1px 0 1px 14px; list-style: none; }
  ul.sub li::before { content: "○ "; }
  ul.sub li { font-size: 8.3pt; line-height: 1.35; }

  /* ── BOTTOM: one row, participant large, IF small beside info box ── */
  .bottom-wrap {
    display: grid;
    grid-template-columns: 1.8fr 0.6fr 1fr;
    gap: 0 12px;
    margin-top: 6px;
    border-top: 1.5px solid #000;
    padding-top: 6px;
    align-items: start;
  }

  .sig-block-title    { font-size: 8.5pt; font-weight: bold; margin-bottom: 4px; }
  .sig-block-title-sm { font-size: 7.5pt; font-weight: bold; margin-bottom: 3px; color: #333; }

  /* Participant sig: big line + name/rel + date */
  .par-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px 10px;
  }
  .par-grid .sig-line-lg {
    grid-column: 1 / -1;
    border-bottom: 1.5px solid #333;
    height: 30px;
    margin-bottom: 1px;
  }
  .par-lbl { font-size: 7pt; color: #555; }

  .sf { display: flex; flex-direction: column; }
  .sf .lbl { font-size: 7pt; color: #555; margin-bottom: 1px; }
  .sf input[type="text"] {
    border: none; border-bottom: 1px solid #555;
    padding: 1px 2px; font-size: 9.5pt;
    font-family: Arial, sans-serif; background: transparent; outline: none; width: 100%;
  }

  /* IF sig: compact stacked */
  .if-col { display: flex; flex-direction: column; gap: 4px; }
  .if-name-input {
    border: none; border-bottom: 1px solid #555;
    padding: 1px 2px; font-size: 8.5pt; font-weight: bold;
    font-family: Arial, sans-serif; background: transparent; outline: none; width: 100%;
  }
  .sig-img-wrap-sm {
    position: relative;
    height: 26px;
  }
  .sig-img-wrap-sm img {
    position: absolute; bottom: 0; left: 0;
    height: 24px; width: auto;
  }
  .sig-img-wrap-sm .sig-underline {
    position: absolute; bottom: 0; left: 0; right: 0;
    border-bottom: 1px solid #333;
  }
  .sig-lbl { font-size: 6.5pt; color: #555; margin-top: 1px; }

  /* Info box */
  .pi-box {
    border: 1px solid #bbb; border-radius: 3px; padding: 5px 8px;
    background: #fafafa;
  }
  .pi-title { font-weight: bold; font-size: 8.5pt; margin-bottom: 4px; text-align: center; border-bottom: 1px solid #ccc; padding-bottom: 2px; }
  .pi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 10px; }
  .pi-row { display: flex; flex-direction: column; }
  .pi-row .lbl { font-size: 7pt; color: #555; margin-bottom: 1px; }
  .pi-row input[type="text"] {
    border: none; border-bottom: 1px solid #666;
    padding: 1px 2px; font-size: 9.5pt;
    font-family: Arial, sans-serif; background: transparent; outline: none; width: 100%;
  }
  .pi-row select {
    border: 1px solid #888; border-radius: 2px; padding: 2px 3px;
    font-size: 8.5pt; font-family: Arial, sans-serif;
    background: #fff; cursor: pointer; outline: none; width: 100%;
  }

  .print-btn {
    display: block; margin: 7px auto 0; padding: 6px 24px;
    background: #2a5fad; color: #fff; font-size: 9.5pt; font-weight: bold;
    border: none; border-radius: 4px; cursor: pointer;
  }
  .print-btn:hover { background: #1c448a; }
</style>
</head>
